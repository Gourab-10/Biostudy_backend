# ─── BioSpark Backend Environment Variables ───
# Copy this file to .env and fill in your values.

# Server
PORT=5000
NODE_ENV=development

# PostgreSQL Database URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://biospark_user:your_secure_password@localhost:5432/biospark_db"

# JWT Secret (generate a strong random string for production)
JWT_SECRET="change_this_to_a_very_long_random_string_for_production"
JWT_EXPIRES_IN="7d"

# File Upload Directory (for PDFs and avatars stored on VPS)
UPLOAD_DIR="./uploads"

# Frontend URL (for CORS)
FRONTEND_URL="*"
